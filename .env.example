# EJEMPLO: .env.example
# Este archivo debe servir solo como referencia. NO incluir secretos reales en el repositorio.
# Copia este archivo a `.env` y luego reemplaza los valores con los de tu entorno local/producción.

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Configuración de la Base de Datos (PostgreSQL)
# Estructura: postgres://usuario:password@host:puerto/nombre_bd
# En este ejemplo se muestran valores de plantilla. Sustituye por los valores reales.
DATABASE_URL=postgres://tu_usuario:tu_password@localhost:5432/smartgym_db

# Seguridad y Autenticación (Requerimiento 2.1)
# WARNING: JWT_SECRET en este archivo es solo un marcador. Use una clave fuerte en producción.
JWT_SECRET=tu_clave_secreta_para_firmar_tokens
JWT_EXPIRES_IN=24h

# Configuración para Docker (Opcional pero recomendado para el despliegue)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=smartgym_db
